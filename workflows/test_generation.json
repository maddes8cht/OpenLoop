{
  // Simple test-generation workflow for repos WITHOUT existing tests.
  // Amala analyses the codebase, Vera generates/improves tests.
  // No preparation agent needed — starts generating right away.
  "preparation_agent": null,
  "loop_agents": ["amala", "vera"],
  "finalization_agent": null,
  "end_state_condition": "is_complete == True",
  "max_loops": 10,
  "finalize_on_abort": false
}
